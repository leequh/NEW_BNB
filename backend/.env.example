# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bnb_db"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-here-make-it-long-and-random"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here-make-it-different-from-jwt-secret"

# Server
PORT=5000
NODE_ENV=development

# Firebase (for image upload)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL="your-firebase-client-email@your-project.iam.gserviceaccount.com"
FIREBASE_STORAGE_BUCKET="your-firebase-storage-bucket.appspot.com"

# CORS
FRONTEND_URL="http://localhost:3000"
